{
  "name": "oh-my-pm",
  "version": "0.2.0-rc.1",
  "private": true,
  "description": "Local project intelligence system for structured project and product delivery.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:contracts": "node tools/gen-contracts.mjs",
    "build:kernel": "cargo build --workspace && node tools/build-kernel-wasm.mjs",
    "build": "pnpm -r build",
    "test": "vitest run && cargo test --workspace",
    "validate:public": "./tools/check-public-surface.sh",
    "validate:structure": "node tools/validate-structure.mjs",
    "validate:boundaries": "node tools/validate-boundaries.mjs",
    "validate:contracts": "node tools/validate-contracts.mjs",
    "version:check": "node tools/check-version-consistency.mjs",
    "validate": "pnpm validate:public && pnpm validate:structure && pnpm validate:boundaries && pnpm validate:contracts && pnpm version:check",
    "mcp:smoke": "node tools/check-mcp-server.mjs",
    "local:install": "node tools/install-local.mjs",
    "local:check": "node tools/check-local-install.mjs",
    "mcp:config": "node tools/print-mcp-client-config.mjs",
    "release:preview": "node tools/build-release-bundle.mjs",
    "release:bundle": "node tools/build-release-bundle.mjs",
    "release:check": "node tools/check-release-bundle.mjs",
    "release:archives:preview": "node tools/build-release-archives.mjs",
    "release:archives": "node tools/build-release-archives.mjs",
    "release:archives:check": "node tools/check-release-archives.mjs",
    "release:archives:repro": "node tools/check-release-archive-reproducibility.mjs",
    "release:install": "node tools/install-release-bundle.mjs",
    "release:install:check": "node tools/check-release-install.mjs",
    "github:smoke": "node tools/check-github-provider-live.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
